// yolo-jail module manifest. See src/modules.py for the schema.
// This file is installed to ~/.local/share/yolo-jail/modules/claude-oauth-broker/
// by `just deploy`. The ca.crt alongside it is generated on first run by
// `yolo-claude-oauth-broker --init-ca` (also triggered during `just deploy`).
{
  "name": "claude-oauth-broker",
  "description": "MITM proxy that serializes Claude OAuth refreshes across jails. Eliminates the refresh-token rotation race that causes intermittent 401 logouts.",
  "version": 1,
  "enabled": true,
  // Jails route this hostname to broker_ip via --add-host, so Claude Code's
  // OAuth calls land on our daemon instead of Anthropic. The broker either
  // serves a cached access token (cache hit) or forwards to real upstream
  // under flock (cache miss), then writes the new tokens to the shared
  // credentials file that all jails bind-mount.
  "intercepts": [
    {"host": "platform.claude.com"}
  ],
  // host.containers.internal on podman/docker bridge. The broker daemon
  // binds to this IP so every running jail can reach it. If your runtime
  // uses a different gateway, override this key.
  "broker_ip": "169.254.1.2",
  // Auto-trusted in the jail via NODE_EXTRA_CA_CERTS.
  "ca_cert": "ca.crt",
  "doctor_cmd": ["yolo-claude-oauth-broker", "--self-check"]
}
