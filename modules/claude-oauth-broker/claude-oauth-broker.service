[Unit]
Description=Claude OAuth broker for yolo-jail (MITM refresh serializer)
Documentation=https://github.com/mschulkind-oss/yolo-jail/blob/main/docs/claude-oauth-mitm-proxy-plan.md
After=network-online.target
Wants=network-online.target

[Service]
# Placeholder replaced by `just deploy` with the absolute path of the
# broker console script shipped by the yolo-jail wheel.
ExecStart=@@BROKER_BIN@@ --host 169.254.1.2 --port 443
Restart=on-failure
RestartSec=5s

# Privilege: listening on :443 needs CAP_NET_BIND_SERVICE. User-level systemd
# can grant this via AmbientCapabilities when NoNewPrivileges is off and the
# kernel allows it. If this fails on your host, switch --port to 8443 and
# arrange DNAT on the container bridge (see modules/claude-oauth-broker/README).
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE

# Sandboxing — the daemon only needs to read/write the module dir and the
# shared credentials file.
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%h/.local/share/yolo-jail/modules/claude-oauth-broker %h/.local/share/yolo-jail/home/.claude
PrivateTmp=yes
NoNewPrivileges=no

[Install]
WantedBy=default.target
