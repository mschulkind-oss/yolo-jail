{
  "mcpServers": {
    "chrome-devtools": {
      "command": "/home/agent/.local/bin/mcp-wrappers/node",
      "args": [
        "/home/agent/.npm-global/bin/chrome-devtools-mcp",
        "--headless",
        "--isolated",
        "--executablePath",
        "/usr/bin/chromium",
        "--chrome-arg=--no-sandbox",
        "--chrome-arg=--disable-dev-shm-usage",
        "--chrome-arg=--disable-setuid-sandbox",
        "--chrome-arg=--disable-gpu",
        "--chrome-arg=--disable-software-rasterizer"
      ]
    },
    "sequential-thinking": {
      "command": "/home/agent/.local/bin/mcp-wrappers/node",
      "args": [
        "/home/agent/.npm-global/bin/mcp-server-sequential-thinking"
      ]
    }
  }
}